# Example environment file for scheduling-backend-test
# copy to .env and fill in appropriate values

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# optional override port
#PORT=4000

# Twilio SendGrid email configuration
# set this to your API key when ready
SENDGRID_API_KEY=your_sendgrid_api_key_here
# sender address for outgoing emails (defaults to wendys05@my.yorku.ca)
EMAIL_SENDER=wendys05@my.yorku.ca
